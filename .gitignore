# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── PyInstaller ───────────────────────────────────────────────────────────────
*.spec
!binah.spec
!simur.spec

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env/

# ── User project & config files (not for sharing) ────────────────────────────
*.otproj
.binah_config.json
.claude/settings.local.json

# ── Archives ──────────────────────────────────────────────────────────────────
*.zip
*.tar.gz

# ── OS cruft ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Local upstream checkout used to vendor sgmanalysis into this repo
SGMPython/

# Nested git repos (separate projects, not submodules)
binah/

# Build / pip caches
.build-python/
.pip-cache/
.pip-tmp/

# Logs and error dumps
log.dat
*.dat
.feff.error

# User-local settings not meant for sharing
binah_settings.json

# Claude Code internal files (settings.local.json already excluded above)
.claude/
